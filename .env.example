# API URL — leave empty to use Vite proxy in development
# Set to full backend URL in production (e.g. https://api.yoursite.com/api)
VITE_API_URL=

# Backend URL for Vite dev proxy (development only)
VITE_BACKEND_URL=http://localhost:4000

# ─── Azure AD / Entra ID OAuth 2.0 Configuration ─────────────────
# Leave VITE_AZURE_CLIENT_ID empty to use username/password login only.
# Set it to enable "Sign in with Microsoft" OAuth 2.0 flow.
# Same CLIENT_ID is used for both frontend and backend (single app registration).

# Application (client) ID from Azure Portal → App Registrations → Cashio
VITE_AZURE_CLIENT_ID=

# Directory (tenant) ID from Azure Portal → Microsoft Entra ID → Overview
VITE_AZURE_TENANT_ID=

# Redirect URI (must match what's configured in Azure App Registration)
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# API scope for access token (api://<CLIENT_ID>/access_as_user)
VITE_AZURE_API_SCOPE=
